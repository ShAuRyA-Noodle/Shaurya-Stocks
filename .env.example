# ============================================================
# QUANT PLATFORM — ENVIRONMENT TEMPLATE
# ============================================================
# Copy to .env.local and fill in. NEVER commit .env.local.
# ============================================================

# ---- App ----
APP_ENV=development                          # development | staging | production
APP_NAME=quant-platform
APP_DEBUG=true
APP_LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
APP_TIMEZONE=America/New_York

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_64_BYTES
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14
BCRYPT_ROUNDS=12

# ---- Database (Postgres + TimescaleDB) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=quant
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant_dev_pw
DATABASE_URL=postgresql+psycopg://quant:quant_dev_pw@postgres:5432/quant
DATABASE_URL_SYNC=postgresql+psycopg://quant:quant_dev_pw@postgres:5432/quant

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ---- MinIO (S3-compatible object store) ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=quant
MINIO_SECRET_KEY=quant_dev_minio
MINIO_BUCKET_MODELS=models
MINIO_BUCKET_REPORTS=reports
MINIO_BUCKET_DATA=data
MINIO_SECURE=false

# ---- MLflow ----
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_EXPERIMENT_NAME=quant-platform

# ============================================================
# PROVIDER API KEYS (every one is used — see docs/adapters.md)
# ============================================================

# ---- Polygon.io ---- (Tier 1 — primary OHLCV, corporate actions, news v2)
POLYGON_API_KEY=

# ---- Alpaca ---- (Tier 1 — paper/live broker + WebSocket streaming)
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets
ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v2/iex
ALPACA_PAPER=true

# ---- FRED ---- (Tier 1 — macro: VIX, yields, DXY, CPI, unemployment)
FRED_API_KEY=

# ---- Groq ---- (Tier 2 — LLM for news sentiment + signal explanations)
GROQ_API_KEY=
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.3-70b-versatile

# ---- Finnhub ---- (Tier 2 — earnings, insider, sentiment, recommendations)
FINNHUB_API_KEY=

# ---- Tiingo ---- (Tier 2 — OHLCV fallback, fundamentals, IEX)
TIINGO_API_KEY=

# ---- Marketaux ---- (Tier 2 — financial-tagged news)
MARKETAUX_API_KEY=

# ---- NewsAPI ---- (Tier 3 — general news fallback)
NEWSAPI_KEY=

# ---- FMP ---- (Tier 3 — analyst targets, estimates, revisions)
FMP_API_KEY=

# ---- Nasdaq Data Link ---- (Tier 3 — free macro + alt datasets)
NASDAQ_DATA_LINK_API_KEY=

# ---- Alpha Vantage ---- (Tier 4 — last-resort fallback, FX)
ALPHAVANTAGE_API_KEY=

# ---- SEC EDGAR ---- (no key — just a User-Agent email per SEC rules)
SEC_EDGAR_USER_AGENT=

# ---- Reddit ---- (DEFERRED — skipping for v1)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=

# ============================================================
# TRADING / RISK DEFAULTS
# ============================================================
TRADING_ENABLED=false                        # master kill switch
UNIVERSE=SP500_NDX100                        # SP500 | NDX100 | SP500_NDX100 | R1000
INITIAL_CAPITAL_USD=100000
MAX_POSITION_PCT=0.05                        # 5% of equity per position
MAX_POSITIONS=20
MAX_SECTOR_PCT=0.30
DAILY_LOSS_LIMIT_PCT=0.02                    # 2% daily loss → halt
DRAWDOWN_KILL_PCT=0.15                       # 15% peak-to-trough → halt
TRANSACTION_COST_BPS=5                       # 5 basis points
SLIPPAGE_BPS=3

# ---- Frontend (public — keep minimal) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/v1
# No API key in NEXT_PUBLIC_* — auth is via httpOnly cookie set by the API
